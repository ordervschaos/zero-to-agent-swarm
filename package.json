{
  "name": "zero-to-agent-swarm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "worker:coder": "AGENT_NAME=coder tsx src/index.ts",
    "worker:researcher": "AGENT_NAME=researcher tsx src/index.ts",
    "worker:writer": "AGENT_NAME=writer tsx src/index.ts",
    "manager": "AGENT_NAME=manager tsx src/index.ts",
    "swarm": "concurrently --names 'manager,coder,researcher,writer' --prefix-colors 'cyan,green,yellow,magenta' 'npm run manager' 'npm run worker:coder' 'npm run worker:researcher' 'npm run worker:writer'"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@google/genai": "^1.44.0"
  }
}
